{
  "name": "mk-projetos",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "predev": "powershell -NoProfile -ExecutionPolicy Bypass -Command \"$ports=@(3001,5173); foreach ($port in $ports) { $ids=(Get-NetTCPConnection -LocalPort $port -ErrorAction SilentlyContinue | Select-Object -ExpandProperty OwningProcess -Unique); foreach ($id in $ids) { if ($id -and $id -ne $PID) { Stop-Process -Id $id -Force -ErrorAction SilentlyContinue } } }\"",
    "dev": "turbo run dev --filter=server --filter=client --filter=desktop",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "db:push": "pnpm --filter server prisma db push",
    "db:migrate": "pnpm --filter server prisma migrate dev",
    "db:studio": "pnpm --filter server prisma studio",
    "db:seed": "pnpm --filter server tsx prisma/seed.ts",
    "db:import-asana-comments": "pnpm --filter server run db:import-asana-comments",
    "desktop:dev": "pnpm --filter desktop dev",
    "desktop:build": "pnpm --filter desktop build"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.15.21",
    "turbo": "^2.5.8",
    "typescript": "^5.8.3"
  }
}
