{
  "appId": "br.eng.mk.mkprojetos",
  "productName": "Mika",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**",
    "package.json"
  ],
  "extraResources": [
    {
      "from": "../client/dist",
      "to": "client"
    }
  ],
  "publish": [
    {
      "provider": "generic",
      "url": "http://localhost:3001/binaries/desktop/win"
    }
  ],
  "win": {
    "target": "nsis",
    "signAndEditExecutable": false,
    "forceCodeSigning": false
  },
  "nsis": {
    "oneClick": false,
    "perMachine": true,
    "allowToChangeInstallationDirectory": true
  }
}
