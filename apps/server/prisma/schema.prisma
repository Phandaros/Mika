generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

/// Usuários do app e usuários importados do Asana.
/// Para usuários vindos do Asana, `passwordHash` pode ficar nulo.
model User {
  id           String  @id @default(cuid())
  asanaGid     String? @unique
  email        String  @unique
  name         String
  passwordHash String?
  role         String  @default("MEMBER")
  isActive     Boolean @default(true)

  photo21x21    String?
  photo27x27    String?
  photo36x36    String?
  photo60x60    String?
  photo128x128  String?
  photoOriginal String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  ownedProjects         Project[]                  @relation("ProjectOwner")
  assignedTasks         Task[]                     @relation("TaskAssignee")
  createdCustomFields   AsanaCustomField[]         @relation("CustomFieldCreatedBy")
  projectFollowers      ProjectFollower[]
  projectMembers        ProjectMember[]
  taskFollowers         TaskFollower[]
  taskLikes             TaskLike[]
  comments              Comment[]
  taskActivities        TaskActivity[]
  notifications         Notification[]
  authoredNotifications Notification[]             @relation("NotificationActor")
  createdHolidays       CompanyHoliday[]           @relation("HolidayCreator")
  createdTasks          Task[]                     @relation("TaskCreator")
  requestedReviews      TaskReview[]               @relation("TaskReviewRequester")
  assignedReviews       TaskReview[]               @relation("TaskReviewReviewer")
  uploadedAttachments   Attachment[]               @relation("AttachmentUploader")
  projectNotes          ProjectNote[]
  meetingMinutes        MeetingMinute[]
  meetingParticipations MeetingMinuteParticipant[]
  weeklyReports         WeeklyReport[]

  @@index([asanaGid])
  @@index([email])
}

model CompanyHoliday {
  id        String   @id @default(cuid())
  date      String   @unique
  name      String
  createdBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  creator User? @relation("HolidayCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([date])
  @@index([createdBy])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  actorId   String?
  type      String
  title     String
  message   String
  read      Boolean  @default(false)
  taskId    String?
  createdAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor User? @relation("NotificationActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([actorId])
  @@index([read])
  @@index([createdAt])
}

model AsanaWorkspace {
  id           String  @id @default(cuid())
  asanaGid     String  @unique
  resourceType String?
  name         String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  teams    Team[]
  projects Project[]
}

model Team {
  id           String  @id @default(cuid())
  asanaGid     String  @unique
  name         String
  description  String?
  workspaceGid String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workspace AsanaWorkspace? @relation(fields: [workspaceGid], references: [asanaGid])
  projects  Project[]

  @@index([workspaceGid])
}

model Project {
  id       String @id @default(cuid())
  asanaGid String @unique

  name         String
  notes        String?
  htmlNotes    String?
  permalinkUrl String?
  platform     String?
  builder      String?
  areaM2       Float?

  archived    Boolean @default(false)
  color       String?
  public      Boolean @default(false)
  defaultView String?

  /// Status atual do projeto no Asana, quando existir.
  currentStatusGid   String?
  currentStatusColor String?
  currentStatusText  String?
  statusUpdateGid    String?

  /// Campos date-only do Asana são mantidos como String para preservar YYYY-MM-DD.
  startOn String?
  dueOn   String?
  dueDate String?

  asanaCreatedAt  DateTime?
  asanaModifiedAt DateTime?

  ownerGid     String?
  teamGid      String?
  workspaceGid String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner     User?          @relation("ProjectOwner", fields: [ownerGid], references: [asanaGid])
  team      Team?          @relation(fields: [teamGid], references: [asanaGid])
  workspace AsanaWorkspace @relation(fields: [workspaceGid], references: [asanaGid])

  sections          Section[]
  memberships       TaskMembership[]
  followers         ProjectFollower[]
  members           ProjectMember[]
  customFieldValues ProjectCustomFieldValue[]
  projectNotes      ProjectNote[]
  meetingMinutes    MeetingMinute[]

  @@index([name])
  @@index([ownerGid])
  @@index([teamGid])
  @@index([workspaceGid])
  @@index([archived])
}

model ProjectFollower {
  id        String @id @default(cuid())
  projectId String
  userGid   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userGid], references: [asanaGid], onDelete: Cascade)

  @@unique([projectId, userGid])
  @@index([userGid])
}

model ProjectMember {
  id        String @id @default(cuid())
  projectId String
  userGid   String

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userGid], references: [asanaGid], onDelete: Cascade)

  @@unique([projectId, userGid])
  @@index([userGid])
}

model Section {
  id       String @id @default(cuid())
  asanaGid String @unique
  name     String

  projectGid     String
  asanaCreatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project          @relation(fields: [projectGid], references: [asanaGid], onDelete: Cascade)
  memberships TaskMembership[]

  @@index([projectGid])
  @@index([name])
}

model Task {
  id       String @id @default(cuid())
  asanaGid String @unique

  name         String
  notes        String?
  htmlNotes    String?
  resourceType String?

  assigneeStatus String?
  completed      Boolean @default(false)
  liked          Boolean @default(false)
  numLikes       Int     @default(0)
  numSubtasks    Int     @default(0)

  /// Campo local opcional para sua aplicação, sem depender do Asana.
  /// Status Mika opcional, preservado na coluna legado `localStatus`.
  mikaStatus String? @map("localStatus")
  priority   String?

  /// Datas completas do Asana.
  dueAt            DateTime?
  completedAtAsana DateTime?
  asanaCreatedAt   DateTime?
  asanaModifiedAt  DateTime?

  /// Campos date-only do Asana são mantidos como String para preservar YYYY-MM-DD.
  dueOn   String?
  startOn String?

  /// Esforço planejado (dias) para gráficos de carga; independente do Asana.
  estimatedDays  Float?
  platform       String?
  discipline     String?
  estimatedTime  Float?
  maxDeadline    DateTime?
  conclusionDays Float?
  stage          String?

  assigneeGid        String?
  createdByUserId    String?
  workflowRootTaskId String?
  adjustmentNumber   Int     @default(0)

  /// `parentAsanaGid`/`parentName` preservam o vínculo mesmo se o parent não estiver no dump.
  parentAsanaGid String?
  parentName     String?
  parentId       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignee            User?  @relation("TaskAssignee", fields: [assigneeGid], references: [asanaGid])
  creator             User?  @relation("TaskCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  parent              Task?  @relation("TaskSubtasks", fields: [parentId], references: [id])
  subtasks            Task[] @relation("TaskSubtasks")
  workflowRoot        Task?  @relation("TaskWorkflowRoot", fields: [workflowRootTaskId], references: [id])
  workflowAdjustments Task[] @relation("TaskWorkflowRoot")

  memberships       TaskMembership[]
  followers         TaskFollower[]
  likes             TaskLike[]
  tags              TaskTag[]
  customFieldValues TaskCustomFieldValue[]
  comments          Comment[]
  activities        TaskActivity[]
  requestedReviews  TaskReview[]           @relation("TaskReviewSource")
  rootReviews       TaskReview[]           @relation("TaskReviewRoot")
  weeklyReportItems WeeklyReportItem[]

  @@index([name])
  @@index([assigneeGid])
  @@index([createdByUserId])
  @@index([workflowRootTaskId])
  @@index([parentAsanaGid])
  @@index([parentId])
  @@index([completed])
  @@index([dueOn])
}

model TaskReview {
  id            String    @id @default(cuid())
  sourceTaskId  String
  rootTaskId    String
  reviewerId    String
  requestedById String?
  status        String    @default("PENDING")
  message       String?
  startOn       String?
  dueOn         String?
  decidedAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sourceTask  Task  @relation("TaskReviewSource", fields: [sourceTaskId], references: [id], onDelete: Cascade)
  rootTask    Task  @relation("TaskReviewRoot", fields: [rootTaskId], references: [id], onDelete: Cascade)
  reviewer    User  @relation("TaskReviewReviewer", fields: [reviewerId], references: [id], onDelete: Restrict)
  requestedBy User? @relation("TaskReviewRequester", fields: [requestedById], references: [id], onDelete: SetNull)

  @@index([rootTaskId])
  @@index([reviewerId])
  @@index([requestedById])
  @@index([status])
  @@index([createdAt])
}

model Comment {
  id       String  @id @default(cuid())
  taskId   String
  authorId String?
  content  String

  /// Idempotência / rastreio de comentários importados do Asana
  asanaGid       String?   @unique
  authorAsanaGid String?
  asanaCreatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  task        Task         @relation(fields: [taskId], references: [id], onDelete: Cascade)
  author      User?        @relation(fields: [authorId], references: [id], onDelete: SetNull)
  attachments Attachment[]

  @@index([taskId])
  @@index([authorId])
  @@index([asanaGid])
  @@index([authorAsanaGid])
}

model Attachment {
  id              String         @id @default(cuid())
  commentId       String?
  comment         Comment?       @relation(fields: [commentId], references: [id], onDelete: SetNull)
  projectNoteId   String?
  projectNote     ProjectNote?   @relation(fields: [projectNoteId], references: [id], onDelete: SetNull)
  meetingMinuteId String?
  meetingMinute   MeetingMinute? @relation(fields: [meetingMinuteId], references: [id], onDelete: SetNull)
  filename        String
  storedAs        String
  mimeType        String
  sizeBytes       Int
  uploadedById    String
  uploadedBy      User           @relation("AttachmentUploader", fields: [uploadedById], references: [id])
  createdAt       DateTime       @default(now())

  @@index([commentId])
  @@index([projectNoteId])
  @@index([meetingMinuteId])
  @@index([uploadedById])
}

model ProjectNote {
  id        String   @id @default(cuid())
  projectId String
  title     String
  content   String?
  authorId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  project     Project      @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author      User         @relation(fields: [authorId], references: [id], onDelete: Restrict)
  attachments Attachment[]

  @@index([projectId, updatedAt])
  @@index([authorId])
}

model MeetingMinute {
  id                   String   @id @default(cuid())
  projectId            String
  title                String
  meetingDate          String
  meetingTime          String?
  content              String?
  externalParticipants Json?
  authorId             String
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  project      Project                    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  author       User                       @relation(fields: [authorId], references: [id], onDelete: Restrict)
  participants MeetingMinuteParticipant[]
  attachments  Attachment[]

  @@index([projectId, meetingDate, meetingTime])
  @@index([authorId])
}

model MeetingMinuteParticipant {
  id              String @id @default(cuid())
  meetingMinuteId String
  userId          String

  meetingMinute MeetingMinute @relation(fields: [meetingMinuteId], references: [id], onDelete: Cascade)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([meetingMinuteId, userId])
  @@index([userId])
}

model TaskActivity {
  id           String   @id @default(cuid())
  taskId       String
  actorId      String?
  type         String
  field        String?
  fromValue    String?
  toValue      String?
  metadataJson String?
  createdAt    DateTime @default(now())

  task  Task  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([taskId])
  @@index([actorId])
  @@index([createdAt])
}

model TaskMembership {
  id     String @id @default(cuid())
  taskId String

  projectGid  String?
  projectName String?
  sectionGid  String?
  sectionName String?

  task    Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  project Project? @relation(fields: [projectGid], references: [asanaGid])
  section Section? @relation(fields: [sectionGid], references: [asanaGid])

  @@unique([taskId, projectGid, sectionGid])
  @@index([projectGid])
  @@index([sectionGid])
}

model TaskFollower {
  id      String @id @default(cuid())
  taskId  String
  userGid String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userGid], references: [asanaGid], onDelete: Cascade)

  @@unique([taskId, userGid])
  @@index([userGid])
}

model TaskLike {
  id      String @id @default(cuid())
  taskId  String
  userGid String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userGid], references: [asanaGid], onDelete: Cascade)

  @@unique([taskId, userGid])
  @@index([userGid])
}

model Tag {
  id             String    @id @default(cuid())
  asanaGid       String    @unique
  name           String
  color          String?
  asanaCreatedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tasks TaskTag[]

  @@index([name])
}

model TaskTag {
  id     String @id @default(cuid())
  taskId String
  tagGid String

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagGid], references: [asanaGid], onDelete: Cascade)

  @@unique([taskId, tagGid])
  @@index([tagGid])
}

model AsanaCustomField {
  id       String @id @default(cuid())
  asanaGid String @unique

  name                String
  description         String?
  type                String
  precision           Int?
  format              String?
  currencyCode        String?
  isGlobalToWorkspace Boolean @default(false)
  createdByGid        String?
  mikaKey             String?
  mikaLabel           String?
  mikaTaskField       Boolean @default(false)
  mikaSortOrder       Int?
  mikaListVisible     Boolean @default(true)
  mikaDetailVisible   Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  createdBy     User?                        @relation("CustomFieldCreatedBy", fields: [createdByGid], references: [asanaGid])
  enumOptions   AsanaCustomFieldEnumOption[]
  projectValues ProjectCustomFieldValue[]
  taskValues    TaskCustomFieldValue[]

  @@index([name])
  @@index([type])
  @@index([createdByGid])
  @@index([mikaKey])
  @@index([mikaTaskField])
}

model AsanaCustomFieldEnumOption {
  id       String @id @default(cuid())
  asanaGid String @unique

  customFieldId String
  name          String
  color         String?
  enabled       Boolean @default(true)
  sortOrder     Int?

  customField   AsanaCustomField          @relation(fields: [customFieldId], references: [id], onDelete: Cascade)
  projectValues ProjectCustomFieldValue[]
  taskValues    TaskCustomFieldValue[]

  @@index([customFieldId])
  @@index([name])
}

model ProjectCustomFieldValue {
  id        String @id @default(cuid())
  projectId String

  /// Estes campos preservam o payload do Asana mesmo se a definicao nao tiver sido importada ainda.
  customFieldGid  String
  customFieldName String?
  type            String
  displayValue    String?
  precision       Int?

  textValue   String?
  numberValue Float?

  enumOptionGid   String?
  enumOptionName  String?
  enumOptionColor String?

  multiEnumValues Json?

  customFieldId String?
  enumOptionId  String?

  project     Project                     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  customField AsanaCustomField?           @relation(fields: [customFieldId], references: [id])
  enumOption  AsanaCustomFieldEnumOption? @relation(fields: [enumOptionId], references: [id])

  @@unique([projectId, customFieldGid])
  @@index([customFieldGid])
  @@index([customFieldId])
}

model TaskCustomFieldValue {
  id     String @id @default(cuid())
  taskId String

  /// Estes campos preservam o payload do Asana mesmo se a definição não tiver sido importada ainda.
  customFieldGid  String
  customFieldName String?
  type            String
  displayValue    String?
  precision       Int?

  numberValue Float?

  enumOptionGid   String?
  enumOptionName  String?
  enumOptionColor String?

  customFieldId String?
  enumOptionId  String?

  task        Task                        @relation(fields: [taskId], references: [id], onDelete: Cascade)
  customField AsanaCustomField?           @relation(fields: [customFieldId], references: [id])
  enumOption  AsanaCustomFieldEnumOption? @relation(fields: [enumOptionId], references: [id])

  @@unique([taskId, customFieldGid])
  @@index([customFieldGid])
  @@index([customFieldId])
  @@index([enumOptionGid])
  @@index([enumOptionId])
}

enum WeeklyReportStatus {
  PENDING
  SUBMITTED
  LATE
}

model WeeklyReport {
  id          String             @id @default(cuid())
  userId      String
  user        User               @relation(fields: [userId], references: [id])
  weekStart   DateTime
  weekEnd     DateTime
  status      WeeklyReportStatus @default(PENDING)
  submittedAt DateTime?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  items       WeeklyReportItem[]

  @@unique([userId, weekStart])
  @@index([weekStart])
  @@index([status])
}

model WeeklyReportItem {
  id           String       @id @default(cuid())
  reportId     String
  report       WeeklyReport @relation(fields: [reportId], references: [id], onDelete: Cascade)
  taskId       String
  task         Task         @relation(fields: [taskId], references: [id])
  comment      String       @default("")
  taskSnapshot Json?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([reportId])
  @@index([taskId])
}
