# apps/server/.env
DATABASE_URL="file:./data/mk-projetos.db"
JWT_ACCESS_SECRET="troque-por-segredo-forte-1"
JWT_REFRESH_SECRET="troque-por-segredo-forte-2"
PORT=3001
